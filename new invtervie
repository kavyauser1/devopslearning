name: CI/CD Pipeline

on:
  push:
    branches: [ "main" ]

jobs:
  build-test-deploy:
    runs-on: ubuntu-latest

    steps:
    - name: Checkout code
      uses: actions/checkout@v3

    - name: Set up Python
      uses: actions/setup-python@v4
      with:
        python-version: '3.9'

    - name: Install dependencies
      run: |
        pip install -r app/requirements.txt
        pip install flake8 pytest

    - name: Lint
      run: flake8 app/

    - name: Test
      run: pytest tests/

    - name: Build Docker Image
      run: docker build -t devops-demo .

    - name: Deploy (Mock)
      run: echo "Deploy step - push to server or Kubernetes"
